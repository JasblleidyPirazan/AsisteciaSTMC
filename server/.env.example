# Variables de entorno del backend (Railway)

# Provisto automáticamente por el servicio PostgreSQL de Railway
DATABASE_URL="postgresql://user:password@localhost:5432/asistencia_tenis?schema=public"

# Clave secreta para firmar tokens JWT (256 bits recomendado)
JWT_SECRET="cambia-esto-por-una-clave-larga-y-secreta"
JWT_EXPIRES_IN="12h"

# Entorno
NODE_ENV="development"
PORT=3000

# Administrador inicial (usado por el seed)
ADMIN_EMAIL="admin@tenis.local"
ADMIN_PASSWORD="admin1234"
